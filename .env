# Host user that the postgres container runs as. Set these to `id -u` and
# `id -g` on your machine if the defaults don't match — otherwise files in
# ./postgres-data/ will be owned by the wrong user.

#Because I am on windows I had to set POSTGRES_UID and POSTGRES_GID to 0.
POSTGRES_UID=0
POSTGRES_GID=0

# Connection settings used by src/entity_linking/db.py
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres
